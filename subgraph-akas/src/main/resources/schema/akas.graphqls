extend schema @link(url: "https://specs.apollo.dev/federation/v2.5", import: ["@key"])

type Title @key(fields: "tconst") {
    tconst: ID!
    "All alternative titles, sorted by ordering. Bounded (~dozens per title)."
    akas: [TitleAka!]!
}

type TitleAka {
    ordering: Int!
    title: String!
    region: String
    language: String
    types: [String!]
    attributes: [String!]
    isOriginalTitle: Boolean
}
